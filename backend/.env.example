NODE_ENV=development
PORT=5001

# Base de données MongoDB
MONGODB_URI=mongodb://localhost:27017/deploy-board

# Jenkins (Req 10.3)
JENKINS_URL=http://localhost:8080
JENKINS_USER=
JENKINS_TOKEN=

# SonarQube (Req 10.4) — utiliser un User Token (droit Browse)
SONARQUBE_URL=http://localhost:9000
SONARQUBE_TOKEN=

# Slack (optionnel — Req 15.x)
SLACK_WEBHOOK_URL=

# URL publique de l'application (liens des notifications)
APP_BASE_URL=http://localhost:3000

# --- Authentification ---
# Compte administrateur unique
ADMIN_USERNAME=admin
# Mot de passe en clair (dev) OU hash bcrypt (prod, prioritaire)
ADMIN_PASSWORD=changeme
# ADMIN_PASSWORD_HASH=$2a$10$....
# Secret de signature JWT (générer une valeur aléatoire forte en prod)
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=12h
# Token d'ingestion machine pour les appels du pipeline Jenkins (POST /api/deployments)
DEPLOY_INGEST_TOKEN=change-this-ci-token
